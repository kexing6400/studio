{
  "name": "studio",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Independent Developer Studio",
  "workspaces": [
    "studio/*",
    "dashboard"
  ],
  "scripts": {
    "dev": "npm run dashboard",
    "dashboard": "cd dashboard && npm run dev",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "studio:agents": "cd studio && npm run",
    "clean": "rm -rf node_modules */node_modules .turbo"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.2.0"
}
